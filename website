<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daniel Prado Photography</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111;
      color: white;
    }
    header {
      height: 100vh;
      background: url('images/hero.jpg') center/cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    header div {
      background: rgba(0,0,0,0.45);
      padding: 30px;
    }
    nav {
      position: fixed;
      top: 0;
      width: 100%;
      background: rgba(0,0,0,0.75);
      padding: 15px;
      text-align: center;
    }
    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
    }
    section {
      padding: 60px 20px;
      max-width: 1100px;
      margin: auto;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
    }
    .gallery img {
      width: 100%;
      display: block;
      border-radius: 6px;
    }
    form {
      display: grid;
      gap: 12px;
      max-width: 500px;
    }
    input, textarea, button {
      padding: 12px;
      border: none;
      border-radius: 4px;
    }
    button {
      background: white;
      color: black;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <nav>
    <a href="#portfolio">Portfolio</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </nav>

  <header>
    <div>
      <h1>Daniel Prado Photography</h1>
      <p>Portrait • Creative • Editorial</p>
    </div>
  </header>

  <section id="portfolio">
    <h2>Portfolio</h2>
    <div class="gallery">
      <img src="images/photo1.jpg" alt="Portfolio image 1">
      <img src="images/photo2.jpg" alt="Portfolio image 2">
      <img src="images/photo3.jpg" alt="Portfolio image 3">
      <img src="images/photo4.jpg" alt="Portfolio image 4">
    </div>
  </section>

  <section id="about">
    <h2>About</h2>
    <p>I am a photographer focused on portraits, creative sessions, and editorial-style imagery.</p>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <form action="https://formspree.io/f/yourformid" method="POST">
      <input type="text" name="name" placeholder="Your name" required>
      <input type="email" name="email" placeholder="Your email" required>
      <textarea name="message" rows="5" placeholder="Your message" required></textarea>
      <button type="submit">Send</button>
    </form>
  </section>
</body>
</html>
